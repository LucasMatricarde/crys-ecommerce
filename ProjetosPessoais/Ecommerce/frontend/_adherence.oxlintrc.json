{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/brand/**",
              "components/commerce/**",
              "components/core/**",
              "components/navigation/**",
              "ui_kits/storefront/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Syne|Inter|Space Mono))/i]",
        "message": "Font not provided by the design system. Available: Syne, Inter, Space Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tone, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|disabled|iconLeft|iconRight|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, disabled, iconLeft, iconRight, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|color|strokeWidth|key|ref|className|style|children)$/]",
        "message": "<Icon> doesn't accept that prop. Declared props: name, size, color, strokeWidth."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: icon."
      },
      {
        "selector": "JSXOpeningElement[name.name='NavBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:brand|links|active|cartCount|onCart|onNavigate|key|ref|className|style|children)$/]",
        "message": "<NavBar> doesn't accept that prop. Declared props: brand, links, active, cartCount, onCart, onNavigate."
      },
      {
        "selector": "JSXOpeningElement[name.name='PriceChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:price|unit|key|ref|className|style|children)$/]",
        "message": "<PriceChip> doesn't accept that prop. Declared props: price, unit."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProductCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|strain|thc|data|price|image|onAdd|key|ref|className|style|children)$/]",
        "message": "<ProductCard> doesn't accept that prop. Declared props: name, strain, thc, data, price, image, onAdd."
      },
      {
        "selector": "JSXOpeningElement[name.name='ResinBlob'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|glow|key|ref|className|style|children)$/]",
        "message": "<ResinBlob> doesn't accept that prop. Declared props: size, glow."
      },
      {
        "selector": "JSXOpeningElement[name.name='StrainTag'] > JSXAttribute > JSXIdentifier[name!=/^(?:type|thc|key|ref|className|style|children)$/]",
        "message": "<StrainTag> doesn't accept that prop. Declared props: type, thc."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
